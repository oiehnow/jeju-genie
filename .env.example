# ── LLM (★ GPT 키 받으면 아래 한 줄만 채우면 자동으로 GPT로 전환) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini      # gpt-5-mini 사용 시 openai_provider의 max_tokens→max_completion_tokens 확인 필요
# LLM_PROVIDER=auto            # auto | openai | ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b

# ── 제주 데이터소스 커넥터 키 (★ 키 받는 대로 채우고 `python -m app.ingest`) ──
# RAG 콘텐츠형 (관광지/문화 텍스트 → 인덱스 편입)
VISITJEJU_API_KEY=
JEJUITS_CITS_CODE=            # 제주교통정보센터 C-ITS (관광지 커넥터가 사용)
JEJUITS_ITS_CODE=            # 제주교통정보센터 ITS (실시간 교통 — 실시간 도구용)

# 공공데이터포털 계정 공용 serviceKey (data.go.kr REST 다수 + 한국공항공사 운항/혼잡/소음)
DATA_GO_KR_API_KEY=

# 실시간 조회형 (수치/실시간 — RAG 미편입, 라이브 도구용으로 보관)
JEJUDATAHUB_PROJECT_KEY=     # 제주데이터허브 proxy 호출용 projectKey
OPINET_API_KEY=              # 오피넷 유가
KMA_APIHUB_KEY=              # 기상청 API허브 (항공기상/낙뢰, 제주공항 ICAO=RKPC)
VWORLD_API_KEY=              # VWorld 공간정보 (지오코더/검색/지도)

# ── 배포(Cloud Run)용: Chroma 인덱스 GCS 동기화 ──
# GCS_BUCKET=project-65d06dcc-5794-483b-b6f-mlops-quicklab
